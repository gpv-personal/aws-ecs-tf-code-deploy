aws_region      = "eu-west-2"
project_name    = "ecs-cluster"
environment     = "dev"
vpc_cidr        = "10.20.0.0/16"
container_image = "public.ecr.aws/nginx/nginx:stable-alpine"
container_port  = 80
task_cpu        = 256
task_memory     = 512
desired_count   = 2
health_check_path                 = "/"
health_check_matcher              = "200-399"
health_check_grace_period_seconds = 60
codestar_connection_arn  = ""
codestar_connection_name = "your-github-connection"
repo_owner               = "your-github-owner"
repo_name                = "your-repo-name"
repo_branch              = "main"
codebuild_compute_type   = "BUILD_GENERAL1_SMALL"
codebuild_image          = "aws/codebuild/standard:7.0"
terraform_state_key      = "terraform/terraform.tfstate"
