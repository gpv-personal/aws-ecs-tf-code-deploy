aws_region      = "eu-west-2"
project_name    = "ecs-cluster"
environment     = "dev"
vpc_cidr        = "10.20.0.0/16"
container_image = "public.ecr.aws/nginx/nginx:stable-alpine"
container_port  = 80
task_cpu        = 256
task_memory     = 512
desired_count   = 2
ecs_instance_type                     = "t3a.small"
ecs_asg_min_size                      = 1
ecs_asg_max_size                      = 4
ecs_asg_desired_capacity              = 2
ecs_capacity_provider_target_capacity = 100

# Preferred model for multiple services: one container per ECS service.
# You can remove this block and use container_image/container_port instead for a single-service setup.
services = {
	app = {
		image          = "public.ecr.aws/nginx/nginx:stable-alpine"
		container_port = 80
		desired_count  = 2
	}
	api = {
		image             = "public.ecr.aws/docker/library/httpd:2.4"
		container_port    = 80
		desired_count     = 1
		host_headers      = ["api.localtest.me"]
		listener_priority = 110
	}
}

health_check_path                 = "/"
health_check_matcher              = "200-399"
health_check_grace_period_seconds = 180
codestar_connection_arn  = ""
codestar_connection_name = "your-github-connection"
repo_owner               = "your-github-owner"
repo_name                = "your-repo-name"
repo_branch              = "main"
codebuild_compute_type   = "BUILD_GENERAL1_SMALL"
codebuild_image          = "aws/codebuild/standard:7.0"
terraform_state_key      = "terraform/terraform.tfstate"
